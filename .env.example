# ────────────────────────────────────────────────────────────────
# Scout-Workshop — environment configuration
# Copy to .env and fill in real values. Mode 600, owner deployer.
# ────────────────────────────────────────────────────────────────

# OpenRouter — used for embeddings (Gemini Embedding 2 Preview) and
# reranking (Cohere Rerank 4 Pro) ONLY. No Claude reasoning calls go
# through OpenRouter. Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firecrawl — primary scraper. Get key at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram bot token + recipient chat IDs.
# Bot is shared with hermes-home-vps; do not regenerate the token.
# TELEGRAM_CHAT_IDS is comma-separated for future multi-recipient use.
TELEGRAM_BOT_TOKEN=000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_IDS=969126485

# Filesystem layout
SCOUT_WORKSHOP_ROOT=/opt/scout-workshop
SCOUT_VAULT=/opt/scout-workshop/vault
SCOUT_STATE=/opt/scout-workshop/state

# Qdrant — existing instance hermes-qdrant-vps on the same VPS.
# We use only the scout_workshop collection; never touch the others.
QDRANT_HOST=localhost
QDRANT_PORT_REST=6333
QDRANT_PORT_GRPC=6334
QDRANT_COLLECTION=scout_workshop

# Model identifiers passed to OpenRouter
EMBEDDING_MODEL=google/gemini-embedding-2-preview
RERANK_MODEL=cohere/rerank-4-pro
